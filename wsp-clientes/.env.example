# .env — Instancia wsp-clientes
# Copia este archivo como .env en /var/www/wsp-clientes/

# URL base de la API puente (sin slash final)
API_BASE_URL=https://api.batidospitaya.com

# Token secreto compartido entre el VPS y la API
# Debe coincidir con WSP_TOKEN definido en la API PHP
WSP_TOKEN=c5b155ba8f6877a2eefca0183ab18e37fe9a6accde340cf5c88af724822cb50

# Puerto del servidor Express interno (no expuesto a internet)
PORT=3001

# Horario de envío (formato HH:MM, 24h, zona America/Managua)
HORA_INICIO_ENVIO=00:00
HORA_FIN_ENVIO=24:00

# Límites anti-ban
MAX_MENSAJES_DIA=150
MAX_MENSAJES_POR_HORA=50
DELAY_MIN_SEGUNDOS=8
DELAY_MAX_SEGUNDOS=25
WSP_INSTANCIA=wsp-clientes

