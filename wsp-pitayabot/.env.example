# ─────────────────────────────────────────────
#  wsp-pitayabot — Variables de Entorno
#  Copiar a .env y completar los valores reales
# ─────────────────────────────────────────────

# Instancia
PORT=3007
WSP_INSTANCIA=wsp-pitayabot

# API Bridge (api.batidospitaya.com)
API_BASE_URL=https://api.batidospitaya.com
WSP_TOKEN=c5b155ba8f6877a2eefca0183ab18e37fe9a6accde340cf5c88af724822cbf50

# Cifrado AES para tokens de Obsidian (clave maestra 32 chars)
AES_SECRET_KEY=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

# ─────────────────────────────────────────────
#  Optimizaciones de velocidad de respuesta IA
# ─────────────────────────────────────────────

# [Sol. 1] API Key de Google Gemini para clasificar directo desde el bot
# (sin pasar por Hostinger). Obtener en: https://aistudio.google.com/app/apikey
# Si está vacía, el clasificador usa la cascada en clasificar.php como fallback.
GOOGLE_AI_API_KEY=AIzaSyBs04pJWw_s2M8wnLFuxQuiRQsB2UD1kQY

# [Sol. 3] Confianza mínima para ejecutar una acción SIN pedir confirmación.
# Rango: 0.0 – 1.0. Con 0.97 solo frases muy claras se ejecutan directo.
# Para desactivar ejecución directa y siempre pedir confirmación, usar 1.01
AUTO_EXEC_MIN_CONFIANZA=0.97

# Horario (asistente personal = sin restricción)
HORA_INICIO_ENVIO=00:00
HORA_FIN_ENVIO=24:00

# Anti-ban (delay entre mensajes enviados por el bot)
DELAY_MIN_SEGUNDOS=2
DELAY_MAX_SEGUNDOS=6
